  m_Text: "# \u0444\u043E\u0440\u043C\u0430\u0442: a/-180/1,5\r\n\r\n#\u043F\u0435\u0440\u0432\u0430\u044F
    \u0431\u0443\u043A\u0432\u0430:\r\n#\u0435\u0441\u043B\u0438 \u0441\u0442\u043E\u0438\u0442
    \"o\" \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0430\u044F - \u043D\u0430
    \u043A\u0430\u043A\u043E\u0439 \u0433\u0440\u0430\u0434\u0443\u0441 \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u044C
    (\u0442\u0435\u043A\u0443\u0449\u0435\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 
    + \u0433\u0440\u0430\u0434\u0443\u0441)\r\n#\u0435\u0441\u043B\u0438 \u0441\u0442\u043E\u0438\u0442
    \"a\" \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0430\u044F \u0437\u043D\u0430\u0447\u0438\u0442
    - \u043A\u0430\u043A\u043E\u0439 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439
    \u0433\u0440\u0430\u0434\u0443\u0441 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430\r\n\r\n#\u0432\u0442\u043E\u0440\u0430\u044F
    \u0446\u0438\u0444\u0440\u0430 \u044D\u0442\u043E \u0433\u0440\u0430\u0434\u0443\u0441\u044B\r\n#\u0442\u0440\u0435\u0442\u044C\u044F
    \u0446\u0438\u0444\u0440\u0430 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0434\u043E\u043B\u0436\u043D\u043E
    \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u0441\u044F\r\n#\u0441\u0442\u0440\u043E\u043A\u0430
    \u043D\u0430\u0447\u0438\u043D\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0441
    \"#\" \u0438\u0433\u043D\u043E\u0440\u0438\u0440\u0443\u0435\u0442\u0441\u044F\r\n\r\n#\u0435\u0441\u043B\u0438
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u043E\u043A\u043D\u043E \u0442\u043E
    \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435\r\n\r\n\r\na/120/1,5\r\na/60/1,5\r\na/180/1,5\r\na/129/1,5\r\na/270/1,5\r\na/320/1,5\r\na/0/1,5"
